    </node>
    <node id="WalletEvents">
      <data key="d0">WalletEvents</data>
      <data key="d1">concept</data>
      <data key="d2">WalletEvents is a Solidity contract defining events related to wallet activities.</data>
      <data key="d3">chunk-bd0f37ab9e07be52654d940b05a8abd9</data>
      <data key="d4">SWC-106.md</data>
      <data key="d5">1763005031</data>
    </node>
    <node id="WalletAbi">
      <data key="d0">WalletAbi</data>
      <data key="d1">concept</data>
      <data key="d2">WalletAbi is a Solidity contract defining the Application Binary Interface for wallet functionalities.</data>
      <data key="d3">chunk-bd0f37ab9e07be52654d940b05a8abd9</data>
      <data key="d4">SWC-106.md</data>
