    <node id="Multi-sig Scheme">
      <data key="d0">Multi-sig Scheme</data>
      <data key="d1">method</data>
      <data key="d2">A Multi-sig Scheme requires multiple parties to approve an action, increasing security.</data>
      <data key="d3">chunk-bd0f37ab9e07be52654d940b05a8abd9</data>
      <data key="d4">SWC-106.md</data>
      <data key="d5">1763005031</data>
    </node>
    <node id="Owner Index">
      <data key="d0">Owner Index</data>
      <data key="d1">concept</data>
      <data key="d2">Owner Index represents the index of an owner.&lt;SEP&gt;Owner Index refers to the index of an owner, used to track their confirmation status in transactions.</data>
      <data key="d3">chunk-3ffd45c33ac2b157557665907f968f8c&lt;SEP&gt;chunk-325e7cb597212ca943c4948538630c1f</data>
      <data key="d4">SWC-106.md</data>
      <data key="d5">1763005031</data>
    </node>
    <node id="Daily Limit">
      <data key="d0">Daily Limit</data>
      <data key="d1">concept</data>
      <data key="d2">Daily Limit is the maximum amount that can be spent within a single day.</data>
      <data key="d3">chunk-3ffd45c33ac2b157557665907f968f8c</data>
      <data key="d4">SWC-106.md</data>
      <data key="d5">1763005031</data>
    </node>
    <node id="Multiowned">
      <data key="d0">Multiowned</data>
      <data key="d1">concept</data>
      <data key="d2">Multiowned refers to a contract or system that requires multiple owners to authorize actions.</data>
      <data key="d3">chunk-3ffd45c33ac2b157557665907f968f8c</data>
      <data key="d4">SWC-106.md</data>
      <data key="d5">1763005057</data>
    </node>
    <node id="Today">
      <data key="d0">Today</data>
      <data key="d1">concept</data>
      <data key="d2">Today refers to the current day.&lt;SEP&gt;Today represents the current day, used to track spending against the daily limit.</data>
      <data key="d3">chunk-3ffd45c33ac2b157557665907f968f8c&lt;SEP&gt;chunk-325e7cb597212ca943c4948538630c1f</data>
      <data key="d4">SWC-106.md</data>
      <data key="d5">1763005057</data>
    </node>
    <node id="Msg.Data">
      <data key="d0">Msg.Data</data>
      <data key="d1">data</data>
      <data key="d2">Msg.data refers to the message data associated with a transaction, used for identifying function calls and parameters.</data>
      <data key="d3">chunk-3ffd45c33ac2b157557665907f968f8c</data>
      <data key="d4">SWC-106.md</data>
      <data key="d5">1763005057</data>
    </node>
    <node id="New Limit">
      <data key="d0">New Limit</data>
      <data key="d1">concept</data>
      <data key="d2">New Limit is the updated daily limit that owners can set, subject to confirmation.</data>
      <data key="d3">chunk-3ffd45c33ac2b157557665907f968f8c</data>
      <data key="d4">SWC-106.md</data>
      <data key="d5">1763005057</data>
    </node>
    <node id="Spent Today">
      <data key="d0">Spent Today</data>
      <data key="d1">concept</data>
      <data key="d2">Spent Today is the amount that has already been spent within the current day.</data>
      <data key="d3">chunk-3ffd45c33ac2b157557665907f968f8c</data>
      <data key="d4">SWC-106.md</data>
      <data key="d5">1763005057</data>
    </node>
    <node id="M_NumOwners">
      <data key="d0">M_NumOwners</data>
      <data key="d1">concept</data>
      <data key="d2">M_NumOwners stores the number of owners.&lt;SEP&gt;M_numOwners refers to the number of owners in the multiowned contract.</data>
      <data key="d3">chunk-3ffd45c33ac2b157557665907f968f8c&lt;SEP&gt;chunk-325e7cb597212ca943c4948538630c1f</data>
      <data key="d4">SWC-106.md</data>
      <data key="d5">1763005057</data>
    </node>
    <node id="InitWallet">
      <data key="d0">InitWallet</data>
      <data key="d1">method</data>
      <data key="d2">InitWallet is the function to initialize the wallet with owners, required confirmations, and the daily limit.</data>
      <data key="d3">chunk-3ffd45c33ac2b157557665907f968f8c</data>
      <data key="d4">SWC-106.md</data>
      <data key="d5">1763005057</data>
    </node>
    <node id="Kill">
      <data key="d0">Kill</data>
      <data key="d1">method</data>
      <data key="d2">Kill is a function that destroys the contract, sending all funds to a specified address.</data>
      <data key="d3">chunk-3ffd45c33ac2b157557665907f968f8c</data>
      <data key="d4">SWC-106.md</data>
      <data key="d5">1763005082</data>
    </node>
    <node id="Execute">
      <data key="d0">Execute</data>
      <data key="d1">method</data>
      <data key="d2">Execute is the function to execute a transaction, either immediately or through the multisig process.</data>
      <data key="d3">chunk-3ffd45c33ac2b157557665907f968f8c</data>
      <data key="d4">SWC-106.md</data>
      <data key="d5">1763005082</data>
    </node>
    <node id="Block.Number">
      <data key="d0">Block.Number</data>
      <data key="d1">data</data>
      <data key="d2">Block.number represents the current block number in the blockchain.</data>
      <data key="d3">chunk-3ffd45c33ac2b157557665907f968f8c</data>
      <data key="d4">SWC-106.md</data>
      <data key="d5">1763005082</data>
    </node>
    <node id="ConfirmationNeeded">
      <data key="d0">ConfirmationNeeded</data>
      <data key="d1">event</data>
      <data key="d2">ConfirmationNeeded is an event that is triggered when a transaction requires additional confirmations.</data>
      <data key="d3">chunk-3ffd45c33ac2b157557665907f968f8c</data>
      <data key="d4">SWC-106.md</data>
      <data key="d5">1763005082</data>
    </node>
    <node id="Create">
      <data key="d0">Create</data>
      <data key="d1">method</data>
      <data key="d2">Create is a function that creates a new contract with the given value and code.</data>
      <data key="d3">chunk-3ffd45c33ac2b157557665907f968f8c</data>
      <data key="d4">SWC-106.md</data>
      <data key="d5">1763005082</data>
    </node>
    <node id="InvalidJumpLabel">
      <data key="d0">InvalidJumpLabel</data>
      <data key="d1">concept</data>
      <data key="d2">InvalidJumpLabel is a label to handle errors when contract creation fails.</data>
      <data key="d3">chunk-3ffd45c33ac2b157557665907f968f8c</data>
      <data key="d4">SWC-106.md</data>
      <data key="d5">1763005082</data>
