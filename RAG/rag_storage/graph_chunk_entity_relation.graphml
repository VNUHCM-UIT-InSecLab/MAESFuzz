      <data key="d4">SWC-106.md</data>
      <data key="d5">1763005109</data>
    </node>
    <node id="M_Txs">
      <data key="d0">M_Txs</data>
      <data key="d1">data</data>
      <data key="d2">M_Txs is used to store transaction details.&lt;SEP&gt;M_txs refers to the map of pending transactions identified by their hash.</data>
      <data key="d3">chunk-3ffd45c33ac2b157557665907f968f8c&lt;SEP&gt;chunk-325e7cb597212ca943c4948538630c1f</data>
      <data key="d4">SWC-106.md</data>
      <data key="d5">1763005109</data>
    </node>
    <node id="M_LastDay">
      <data key="d0">M_LastDay</data>
      <data key="d1">data</data>
      <data key="d2">M_LastDay stores the last day the spend limit was reset.&lt;SEP&gt;M_lastDay stores the index of the most recent day, used for comparing against the current day.</data>
      <data key="d3">chunk-3ffd45c33ac2b157557665907f968f8c&lt;SEP&gt;chunk-325e7cb597212ca943c4948538630c1f</data>
      <data key="d4">SWC-106.md</data>
      <data key="d5">1763005109</data>
    </node>
    <node id="InitDaylimit">
      <data key="d0">InitDaylimit</data>
      <data key="d1">method</data>
      <data key="d2">InitDaylimit is the function used to set the initial daily limit and the index of the present day.</data>
      <data key="d3">chunk-3ffd45c33ac2b157557665907f968f8c</data>
      <data key="d4">SWC-106.md</data>
      <data key="d5">1763005109</data>
    </node>
    <node id="ResetSpentToday">
      <data key="d0">ResetSpentToday</data>
      <data key="d1">method</data>
      <data key="d2">ResetSpentToday is the function used to reset the amount already spent today.</data>
      <data key="d3">chunk-3ffd45c33ac2b157557665907f968f8c</data>
      <data key="d4">SWC-106.md</data>
      <data key="d5">1763005109</data>
    </node>
    <node id="Only_Uninitialized">
      <data key="d0">Only_Uninitialized</data>
      <data key="d1">concept</data>
      <data key="d2">Only_uninitialized is a modifier that prevents the contract from being initialized if it is already initialized.</data>
